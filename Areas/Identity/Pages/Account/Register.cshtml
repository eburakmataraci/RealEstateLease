@page
@model RealEstateLease.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="form-container">
    <h1 class="form-title">Kayıt Ol</h1>
    <p class="form-subtitle">Sistemi kullanmak için birkaç bilgiyi doldurmanız yeterli.</p>

    <form method="post">
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Input.FullName" class="form-label">Ad Soyad</label>
            <input asp-for="Input.FullName" class="form-control" />
            <span asp-validation-for="Input.FullName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Email" class="form-label">E-posta</label>
            <input asp-for="Input.Email" class="form-control" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Password" class="form-label">Şifre</label>
            <input asp-for="Input.Password" type="password" class="form-control" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.ConfirmPassword" class="form-label">Şifre Tekrar</label>
            <input asp-for="Input.ConfirmPassword" type="password" class="form-control" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.UserType" class="form-label">Kullanıcı Tipi</label>
            <select asp-for="Input.UserType" class="form-control">
                <option value="">Seçiniz</option>
                <option value="Admin">Admin</option>
                <option value="Owner">Ev Sahibi</option>
                <option value="Tenant">Kiracı</option>
            </select>
            <span asp-validation-for="Input.UserType" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 mt-3">Kayıt Ol</button>

        <div class="mt-3 text-center">
            <a asp-page="./Login">Zaten hesabın var mı? Giriş yap</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
