@using RealEstateLease.Models
@model List<Lease>

@{
    ViewData["Title"] = "Sözleşmelerim";
}

<h2 class="mb-3">Sözleşmelerim</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">Henüz hiç sözleşmeniz yok.</div>
}
else
{
    <table class="table table-striped table-bordered table-hover">
        <thead class="table-light">
            <tr>
                <th>Mülk</th>
                <th>Daire</th>
                <th>Aylık Kira</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var lease in Model)
            {
                <tr>
                    <td>@lease.Unit.Property.Name</td>
                    <td>@lease.Unit.UnitNumber</td>
                    <td>@lease.MonthlyRent.ToString("N0") ₺</td>
                    <td>
                        @if (lease.Status == LeaseStatus.Active)
                        {
                            <span class="badge-status badge-status-active">Aktif</span>
                        }
                        else if (lease.Status == LeaseStatus.PendingSignature)
                        {
                            <span class="badge-status badge-status-pending">İmza Bekliyor</span>
                        }
                        else
                        {
                            <span class="badge-status">@lease.Status</span>
                        }
                    </td>
                    <td>
                        <a class="btn btn-sm btn-info"
                           asp-action="Details"
                           asp-route-id="@lease.Id">
                            Detay
                        </a>

                        @if (lease.Status == LeaseStatus.PendingSignature)
                        {
                            <form asp-action="Sign" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@lease.Id" />
                                <button class="btn btn-sm btn-success">İmzala</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
