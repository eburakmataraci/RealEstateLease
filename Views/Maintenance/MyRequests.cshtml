@using RealEstateLease.Models
@model IEnumerable<RealEstateLease.Models.MaintenanceRequest>

@{
    ViewData["Title"] = "Bakım Taleplerim";
}

<h2 class="mb-3">Bakım Taleplerim</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<p>
    <a class="btn btn-primary" asp-action="Create">Yeni Talep Oluştur</a>
</p>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">
        Henüz bakım talebiniz bulunmuyor.
    </div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead class="table-light">
            <tr>
                <th>Tarih</th>
                <th>Mülk</th>
                <th>Daire</th>
                <th>Başlık</th>
                <th>Durum</th>
                <th>İşlem</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@r.Unit?.Property?.Name</td>
                <td>@r.Unit?.UnitNumber</td>
                <td>@r.Title</td>
                <td>@r.Status</td>
                <td>
                    <a class="btn btn-sm btn-info"
                       asp-action="Details"
                       asp-route-id="@r.Id">
                        Detay
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
