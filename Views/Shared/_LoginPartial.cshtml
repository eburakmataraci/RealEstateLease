@using Microsoft.AspNetCore.Identity
@using RealEstateLease.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav ms-auto">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item me-2 d-flex align-items-center text-white-50 small">
        Merhaba, @User.Identity?.Name
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
            <button type="submit" class="btn btn-outline-light btn-sm rounded-pill px-3">
                Çıkış Yap
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item me-2">
        <a class="btn btn-outline-light btn-sm rounded-pill px-3"
           asp-area="Identity" asp-page="/Account/Login">
            Giriş Yap
        </a>
    </li>
    <li class="nav-item">
        <a class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm"
           asp-area="Identity" asp-page="/Account/Register">
            Kayıt Ol
        </a>
    </li>
}
</ul>
