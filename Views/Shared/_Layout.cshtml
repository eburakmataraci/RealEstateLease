@using Microsoft.AspNetCore.Identity
@using RealEstateLease.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kira Yönetim Sistemi</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RealEstateLease.styles.css" asp-append-version="true" />
</head>

<body class="app-body">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light main-navbar border-bottom box-shadow mb-3">
            <div class="container-fluid">

                <!-- Site Başlığı -->
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon">K</span>
                    <span class="brand-text">Kira Yönetim Sistemi</span>
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Gezinmeyi aç/kapat">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 main-menu">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Property" asp-action="Index">Mülkler</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Lease" asp-action="MyLeases">Sözleşmelerim</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Lease" asp-action="Create">Sözleşme Oluştur</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Payment" asp-action="MyInvoices">Ödemelerim</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Maintenance" asp-action="MyRequests">
                                Bakım Taleplerim
                            </a>
                        </li>

                        @* SAHİP PANELİ *@
                        @if (SignInManager.IsSignedIn(User) && User.IsInRole(AppRoles.Owner))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="ownerDropdown" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    Ev Sahibi
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="ownerDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Owner" asp-action="Dashboard">
                                            Ev Sahibi Paneli
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Maintenance" asp-action="OwnerList">
                                            Bakım Yönetimi
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        @* ADMİN PANELİ *@
                        @if (SignInManager.IsSignedIn(User) && User.IsInRole(AppRoles.Admin))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                    Yönetici Paneli
                                </a>
                            </li>
                        }
                    </ul>

                    <!-- Login / Profil (ReturnUrl YOK!) -->
                    <div class="d-flex align-items-center gap-2">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <span class="me-2">
                                @User.Identity?.Name
                            </span>

                            <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout" method="post">
                                <button type="submit" class="btn btn-outline-light">
                                    Çıkış Yap
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-area="Identity"
                               asp-page="/Account/Login"
                               class="btn btn-outline-light">
                                Giriş Yap
                            </a>

                            <a asp-area="Identity"
                               asp-page="/Account/Register"
                               class="btn btn-primary">
                                Kayıt Ol
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container app-main">
        <div class="app-card app-content">
            @RenderBody()
        </div>
    </div>

    <footer class="border-top app-footer text-muted mt-4">
        <div class="container d-flex flex-wrap justify-content-between align-items-center small">
            <span>© @DateTime.Now.Year - Kira Yönetim Sistemi</span>
            <a asp-controller="Home" asp-action="Privacy">Gizlilik Politikası</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
