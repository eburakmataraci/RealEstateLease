@{
    ViewData["Title"] = "Yönetici Paneli";
}

<h2 class="mb-4">Yönetici Paneli</h2>

<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="text-muted small">Kullanıcı Sayısı</div>
                <div class="fs-4 fw-bold">@ViewBag.TotalUsers</div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="text-muted small">Mülk Sayısı</div>
                <div class="fs-4 fw-bold">@ViewBag.TotalProperties</div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="text-muted small">Daire Sayısı</div>
                <div class="fs-4 fw-bold">@ViewBag.TotalUnits</div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="text-muted small">Aktif Sözleşme</div>
                <div class="fs-4 fw-bold">@ViewBag.TotalLeases</div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4 mb-3">
        <div class="card shadow-sm border-0 bg-light">
            <div class="card-body">
                <div class="text-muted small">Ödenmemiş Toplam (₺)</div>
                <div class="fs-4 fw-bold">@(((decimal)ViewBag.TotalUnpaid).ToString("N0"))</div>
            </div>
        </div>
    </div>
</div>

<h4 class="mt-3">Hızlı İşlemler</h4>
<ul>
    <li><a asp-action="Users">Kullanıcı Yönetimi</a></li>
    <li><a asp-controller="Property" asp-action="Index">Mülk Yönetimi</a></li>
    <li><a asp-controller="Owner" asp-action="Dashboard">Ev Sahibi Dashboard</a></li>
</ul>
